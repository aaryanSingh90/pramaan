# ─── Pramaan environment ─────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values. Never commit `.env`.

# Postgres — local dev uses the macOS user as owner (no password). Adjust as needed.
DATABASE_URL="postgresql://aaryansingh@localhost:5432/pramaan?schema=public"

# Public base URL — used in QR codes, email links, and the `/v/<id>` page.
# In production set to https://pramaan.in (or whatever your domain is).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# JWT signing secret used for institution-staff session cookies.
# Any random 32+ character string. Rotating it logs everyone out.
JWT_SECRET="local-dev-secret-replace-in-production-please"

# HMAC secret used to sign every certificate payload. Tamper detection
# depends on this staying constant. Rotating it after launch marks every
# previously-issued certificate as TAMPERED on the verify page.
CERT_SIGNING_SECRET="rotate-me-but-only-with-migration-plan"

# ─── Email delivery (optional) ────────────────────────────────────────────
# Resend API key. Sign up free at https://resend.com (3000 emails/month).
# LEAVE BLANK to run Pramaan without real email — every send is logged to
# the server console and recorded in EmailLog, but no mail is dispatched.
# Perfect for development / demos.
RESEND_API_KEY=""

# "From" address for outgoing certificate emails. If using Resend's free
# tier without a verified domain, leave this on `onboarding@resend.dev`.
# In production use your own verified domain (e.g. `Pramaan <hi@pramaan.in>`)
# for proper deliverability and SPF/DKIM alignment.
MAIL_FROM="Pramaan <onboarding@resend.dev>"

# ─── Storage (Phase 4) ───────────────────────────────────────────────────
# Cloudflare R2 / AWS S3 — leave blank to store template backgrounds as
# base64 in the database. Fine for the first ~500 templates; switch to
# object storage when you outgrow that.
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
