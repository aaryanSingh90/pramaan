# Copy to .env.local for development.

# Postgres — local dev uses the macOS user as owner (no password).
DATABASE_URL="postgresql://aaryansingh@localhost:5432/pramaan?schema=public"

# JWT signing secret — any random 32+ char string.
JWT_SECRET="local-dev-secret-replace-in-production-please"

# Public base URL — used in QR codes and verification links.
# In production this becomes https://pramaan.in
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# HMAC secret used to sign certificate payloads — tamper detection.
# Must NEVER change after launch or every existing certificate becomes "tampered".
CERT_SIGNING_SECRET="rotate-me-but-only-with-migration-plan"

# Storage (Cloudflare R2 / AWS S3) — leave blank in dev to fall back to local fs.
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
